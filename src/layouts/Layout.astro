---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portafolio de Christopher Rodriguez - Ingeniería en Sistemas ESCOM" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
		<title>{title}</title>
	</head>
	<body>
		<div class="bg-decoration">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
		</div>
		
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--primary: #003366;
		--primary-light: #004d99;
		--accent: #00a8cc;
		--bg-color: #f8faff;
		--text-main: #1a1a1a;
		--text-muted: #555;
	}

	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
		font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-main);
		overflow-x: hidden;
	}

	.bg-decoration {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		overflow: hidden;
		pointer-events: none;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(60px);
		opacity: 0.15;
	}

	.blob-1 {
		top: -50px;
		right: -50px;
		width: 300px;
		height: 300px;
		background: var(--primary);
	}

	.blob-2 {
		bottom: 10%;
		left: -100px;
		width: 350px;
		height: 350px;
		background: var(--accent);
	}

	h1, h2, h3, h4 {
		margin-bottom: 0.5em;
		color: var(--primary);
		font-weight: 700;
	}

	b {
		color: var(--primary);
	}

	* {
		box-sizing: border-box;
		transition: all 0.2s ease-in-out;
	}
</style>