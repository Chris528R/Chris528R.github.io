---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import ContactButton from "../components/ContactButton.astro";

const highlights = [
  {
    title: "Data Analyst @ Datatón INEGI 2026",
    description: "Análisis predictivo de tendencias comerciales para ANTAD usando Python (Pandas/NumPy).",
    icon: "chart-area"
  },
  {
    title: "Full-Stack Developer @ Transatlantic",
    description: "Arquitectura de bases de datos escalables con Node.js y PostgreSQL para rentaclassics.com.",
    icon: "database"
  },
  {
    title: "Backend Developer @ Interledger Hackathon",
    description: "Prototipo funcional de pagos en tiempo real con seguridad reforzada mediante códigos QR.",
    icon: "wallet"
  }
];

const projects = [
  {
    title: "Repositorio: Tratamiento de Datos DATATÓN INEGI 2026",
    description: "Análisis de datos de comercio para determinar la informalidad en México para el Datatón INEGI 2026.",
    link: "https://github.com/Chris528R/economia_informal_analisis",
    tags: ["Python", "Data Analysis", "INEGI"]
  },
  {
    title: "Smart Pot - Tlaliware APP (Winner JA 2025)",
    description: "Dispositivo IoT con ESP32 y Bluetooth para monitoreo de plantas mediante aplicación móvil.",
    link: "https://github.com/Richi-Mi/tlaliware-app",
    tags: ["IoT", "ESP32", "Android"]
  },
  {
    title: "Brújula de las Utopías (Embajada de Francia)",
    description: "Aplicación Android desarrollada para 'La Noche de las Ideas 2025'. Gestión de información de eventos y UI/UX en entorno colaborativo internacional.",
    link: "https://github.com/Richi-Mi/app-la-noche-de-las-ideas",
    tags: ["Android", "Kotlin", "International Collab"]
  }
];
---

<Layout title="Networking | ESCOM IPN">
	<main class="container">
		<header class="hero">
			<img
				src="/Foto.png"
				alt="Christopher Rodriguez Mendoza"
				class="avatar"
			/>
			<h1>Christopher Rodriguez Mendoza</h1>
			<p class="subtitle">
				Software Architecture & AI Student @ <b>ESCOM IPN</b>
			</p>
		</header>

		<section class="links">
			<ContactButton
				label="LinkedIn"
				url="https://www.linkedin.com/in/rodriguez-mendoza-christopher/"
				icon="linkedin"
			/>
			<ContactButton
				label="GitHub"
				url="https://github.com/Chris528R"
				icon="github"
			/>
			<ContactButton label="Download CV" url="/cv.pdf" primary />
		</section>

		<section class="experience">
		<h2>Trayectoria y Logros</h2>
		<div class="highlights-grid">
			{highlights.map(h => (
			<div class="highlight-item">
				<i class={`fas fa-${h.icon}`}></i>
				<div>
				<h4>{h.title}</h4>
				<p>{h.description}</p>
				</div>
			</div>
			))}
		</div>
		</section>

		<section class="action-photo">
		<img src="/Yo.jpeg" alt="Presentando proyectos de tecnología" class="presentation-img" />
		<p class="caption">Presentando soluciones tecnológicas en eventos de innovación.</p>
		</section>


		<section class="projects-grid">
			<h2>Proyectos Destacados</h2>
			{projects.map((p) => <Card {...p} />)}
		</section>

		<footer class="school-footer">
			<p>Delegación de Vinculación <b></b><a href="https://www.escom.ipn.mx/">ESCOM</a></b>
			</p>
			<small>Impulsando la innovación tecnológica en México</small>
		</footer>
		<ContactButton
			label="Vinculación ESCOM"
			url="mailto:escom_upis@ipn.mx?subject=Interés en Vinculación ESCOM"
			icon="university"
		/>
	</main>
</Layout>

<style>
	.container {
		max-width: 600px;
		margin: 0 auto;
		padding: 2rem 1rem;
		text-align: center;
	}
	.avatar {
		width: 160px; 
		height: 200px; 
		object-fit: cover; 
		border-radius: 80px; 
		border: 4px solid #003366;
		margin-bottom: 1.5rem;
		box-shadow: 0 10px 20px rgba(0,0,0,0.1);
	}
	.subtitle {
		color: #555;
		font-size: 1.1rem;
	}

	.highlights-grid {
		text-align: left;
		margin-top: 1rem;
	}
	.highlight-item {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 1.5rem;
		padding: 1rem;
		background: rgba(255, 255, 255, 0.5);
		border-radius: 8px;
	}
	.highlight-item i {
		color: #003366;
		font-size: 1.2rem;
		margin-top: 3px;
	}
	.presentation-img {
		width: 100%;
		border-radius: 12px;
		margin-top: 1rem;
		filter: grayscale(20%);
	}
	.caption {
		font-size: 0.8rem;
		color: #777;
		font-style: italic;
	}

	.btn.primary {
		background: linear-gradient(135deg, #003366 0%, #004d99 100%);
		border: none;
		box-shadow: 0 4px 15px rgba(0,51,102,0.3);
	}

	.presentation-img {
		width: 100%;
		border-radius: 15px;
		border: 8px solid white; 
		box-shadow: 0 5px 15px rgba(0,0,0,0.08);
		margin: 2rem 0;
	}

	.school-footer .btn {
		background: #f8faff;
		border: 2px dashed #003366; 
	}

</style>
